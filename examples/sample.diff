@@ -0,0 +1,35 @@
+"""Tests for governance service."""
+
+from app.services.governance_service import evaluate_governance
+
+
+def test_pii_detection():
+    reasons = evaluate_governance("my email is user@example.com")
+    assert len(reasons) > 0
+
+
+def test_api_key_detection():
+    reasons = evaluate_governance("using key sk-or-v1-abc123def456ghi789jkl")
+    assert len(reasons) > 0
+
+
+def test_clean_prompt():
+    reasons = evaluate_governance("Hello, how are you?")
+    assert len(reasons) == 0
