# REQUIRED
DATABASE_URL=postgresql+psycopg2://sbn:sbn_password@localhost:5432/ai_observability
OPENAI_API_KEY=
SBN_ENCRYPTION_KEY=

# Authentication — generate unique secure values per environment
BOOTSTRAP_ADMIN_API_KEY=
BOOTSTRAP_ANALYST_API_KEY=
BOOTSTRAP_VIEWER_API_KEY=
BOOTSTRAP_INGEST_API_KEY=

# Optional
BACKEND_BASE_URL=http://localhost:8000
OPENAI_BASE_URL=
DEFAULT_AGENT_MODEL=gpt-4o-mini
LATENCY_ALERT_THRESHOLD_MS=1500
COST_ALERT_THRESHOLD=0.05
API_KEY_HEADER_NAME=X-API-Key
BOOTSTRAP_ANALYST_PROJECT_SCOPE=
BOOTSTRAP_VIEWER_PROJECT_SCOPE=
SBN_API_KEY=analyst-local-dev-key
SBN_JSON_LOG=false
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Connection pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ENABLED=true

# Security
TRUSTED_HOSTS=localhost,127.0.0.1
ENFORCE_TRUSTED_HOSTS=false